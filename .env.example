# Platform API keys (you manage these — users never see them)
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# CLI-only fallback (personal use without web app)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Web app
PUBLIC_BASE_URL=http://localhost:8000
CRON_SECRET=change-me-to-a-long-random-string
DATABASE_PATH=app/data.db

# Google Sheets + Drive (optional)
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json
GOOGLE_DOCS_FOLDER_ID=
# Drive OAuth (personal Gmail — run python auth_google_drive.py once)
GOOGLE_OAUTH_CLIENT_SECRETS=client_secret.json
GOOGLE_OAUTH_TOKEN=google_token.json
